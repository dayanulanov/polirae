{
  "name": "polirae",
  "version": "0.0.4",
  "private": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rimraf dist && tsc",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome lint ./src",
    "format": "biome format ./src --write",
    "check": "biome check --write ./src",
    "check:ci": "biome check ./src",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dayanulanov/polirae.git"
  },
  "lint-staged": {
    "*.{js,ts,json}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "keywords": [
    "color",
    "rgb",
    "hex",
    "typescript"
  ],
  "author": "dayanulanov",
  "license": "MIT",
  "type": "module",
  "bugs": {
    "url": "https://github.com/dayanulanov/polirae/issues"
  },
  "homepage": "https://github.com/dayanulanov/polirae#readme",
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@types/node": "^25.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
